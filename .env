# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=youe_database

# JWT配置
JWT_SECRET=your_secure_random_jwt_secret_123!@#
JWT_EXPIRES_IN=7d

# 上传文件配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# 邮件服务配置 (SMTP)
EMAIL_HOST=smtp.126.com
EMAIL_PORT=465
EMAIL_USER=your_email@126.com
EMAIL_PASS=your_email_auth_code
